# =====================================================================
# Frigate Transcribe — example environment file
# =====================================================================
# Copy to .env (or paste these as `environment:` keys in your compose
# file) and fill in the values you care about. Anything left blank or
# unset will use the documented default.

# ---------------------------------------------------------------------
# Source camera
# ---------------------------------------------------------------------
# Frigate camera name (used in the UI title and as the default RTSP
# stream name). The camera must be carrying audio in your Frigate /
# go2rtc config.
TRANSCRIBE_CAMERA=dining
# Full RTSP URL — defaults to rtsp://frigate:8554/${TRANSCRIBE_CAMERA}
# which works if this container is on the same Docker network as
# Frigate. Override if Frigate is on another host.
RTSP_URL=

# ---------------------------------------------------------------------
# Whisper
# ---------------------------------------------------------------------
# Any faster-whisper model name. distil-large-v3 is the sweet spot for
# CPU: ~1.5 GB, near large-v3 quality, much better on non-US accents
# than medium.en. Drop to medium.en if you can't keep up with realtime.
TRANSCRIBE_WHISPER_MODEL=distil-large-v3
TRANSCRIBE_WHISPER_COMPUTE=int8
TRANSCRIBE_WHISPER_THREADS=8
# Beam=5 is Whisper default; drop to 3 on a distilled model for ~30%
# more speed at minimal quality cost.
TRANSCRIBE_WHISPER_BEAM=5
TRANSCRIBE_WHISPER_LANGUAGE=en
# Below this no-speech probability the segment is dropped as silence.
TRANSCRIBE_WHISPER_NO_SPEECH_THRESHOLD=0.6
TRANSCRIBE_WHISPER_LOG_PROB_THRESHOLD=-1.0
# Post-filter — drop segments below this average log-prob (low confidence).
TRANSCRIBE_AVG_LOGPROB_MIN=-0.9
# Drop segments with abnormally high text-vs-audio compression ratio
# (Whisper loop / repeat detector). Natural speech sits around 1.2–1.8.
TRANSCRIBE_COMPRESSION_RATIO_MAX=2.4
# Drop segments whose detected language probability is below this.
# 0 disables. ~0.6 catches music / TV chatter Whisper invents text for.
TRANSCRIBE_LANGUAGE_PROB_MIN=0
# VAD silence gap before splitting segments (ms). 300ms over-fragments
# and strips context; 500ms keeps natural pauses inside one segment.
TRANSCRIBE_VAD_MIN_SILENCE_MS=500

# ---------------------------------------------------------------------
# Audio capture
# ---------------------------------------------------------------------
# Length of each chunk written by ffmpeg (seconds).
TRANSCRIBE_CHUNK_SECONDS=60
# Pre-Whisper ffmpeg audio filter. highpass trims sub-speech rumble;
# loudnorm gives Whisper a consistent LUFS level. Set to "none" to
# disable filtering entirely.
TRANSCRIBE_AUDIO_FILTER=highpass=f=80,loudnorm=I=-18:TP=-1.5:LRA=11
# Kill ffmpeg if no new chunks appear for this many seconds — the loop
# then respawns it. Defaults to 3 × CHUNK_SECONDS.
TRANSCRIBE_FFMPEG_STALL_SECONDS=180
# Drop oldest waiting chunks if more than this many pile up.
TRANSCRIBE_MAX_CHUNK_BACKLOG=30

# ---------------------------------------------------------------------
# Speaker diarisation (Resemblyzer)
# ---------------------------------------------------------------------
# Set to 0 to disable embeddings entirely (saves ~400 MB RAM).
TRANSCRIBE_ENABLE_EMBEDDINGS=1
# Cosine similarity threshold for committing a segment to a speaker
# centroid. 0.78 is the Resemblyzer default; raise for a distant
# microphone where embeddings drift (0.85–0.9). Below this the segment
# is stored as Unknown — better than mis-attributed.
TRANSCRIBE_SPEAKER_MATCH_THRESHOLD=0.78

# ---------------------------------------------------------------------
# LLM correction pass
# ---------------------------------------------------------------------
# Sends each chunk's raw Whisper output through a fast LLM with rolling
# conversation context, asking it to rewrite phonetic-nonsense lines.
# Falls back to raw output on any failure. Off-by-default cost: ~1
# Gemini Flash Lite call per minute of audio.
TRANSCRIBE_LLM_CORRECTION_ENABLED=1
TRANSCRIBE_LLM_CORRECTION_MODEL=gemini-2.5-flash-lite
TRANSCRIBE_LLM_CORRECTION_CONTEXT_LINES=20

# Names of expected speakers (comma-separated). Used both to bias
# Whisper's initial prompt and to remind the correction LLM which
# names not to fabricate. Leave blank if you don't have a stable cast.
TRANSCRIBE_SPEAKER_NAMES=
# Free-form phrase describing where the audio is captured. Plugged
# into the correction prompt to give the model context.
#   examples:  "a kitchen in Sydney"  "a small radio studio"
TRANSCRIBE_LOCATION_HINT=a home
# Free-form phrase describing the dialect / register.
#   examples:  "Australian English"  "American English"  "British English with industry jargon"
TRANSCRIBE_DIALECT_HINT=everyday speech
# Optional comma-separated dialect words to inject into Whisper's initial
# prompt as accent bias. Plain vocabulary fragments — NOT a sentence
# (Whisper will echo a coherent prompt as fake transcript output).
#   AU example:  yeah nah,heaps,reckon,mate,fair enough,alright
TRANSCRIBE_DIALECT_HINT_WORDS=
# Override the auto-built initial prompt entirely if you want full
# control. Leave blank to use the prompt assembled from SPEAKER_NAMES
# and DIALECT_HINT_WORDS.
TRANSCRIBE_WHISPER_INITIAL_PROMPT=

# ---------------------------------------------------------------------
# LLM backend
# ---------------------------------------------------------------------
# gemini = Google Gemini API (free tier, fast)
# ollama = local Ollama (slow on CPU, no API spend)
TRANSCRIBE_LLM_BACKEND=gemini
TRANSCRIBE_GEMINI_API_KEY=
TRANSCRIBE_GEMINI_MODEL=gemini-2.5-flash-lite
# Only used when TRANSCRIBE_LLM_BACKEND=ollama
OLLAMA_URL=http://ollama:11434
TRANSCRIBE_OLLAMA_MODEL=qwen3:4b

# ---------------------------------------------------------------------
# End-of-day summary + Pushover
# ---------------------------------------------------------------------
# Local time HH:MM at which the previous day is summarised and pushed.
TRANSCRIBE_SUMMARY_TIME=00:05
# Skip a summary run if there are fewer than this many segments.
TRANSCRIBE_MIN_SEGMENTS_FOR_SUMMARY=8
# Throttle: minimum seconds between repeat summary runs for one date.
TRANSCRIBE_SUMMARY_MIN_INTERVAL_S=30
# Pushover delivery (leave blank to disable Pushover entirely).
TRANSCRIBE_PUSHOVER_TOKEN=
PUSHOVER_USER_KEY=

# Comma-separated names highlighted in the UI and given dedicated
# sections in summaries (mentions of these names anywhere in text).
TRANSCRIBE_MENTION_WATCHLIST=

# Comma-separated keywords that trigger a priority +1 Pushover when
# heard. Example: help,emergency,fire,ambulance
TRANSCRIBE_KEYWORD_ALERTS=
TRANSCRIBE_KEYWORD_ALERT_COOLDOWN=300

# ---------------------------------------------------------------------
# UI
# ---------------------------------------------------------------------
TRANSCRIBE_UI_PORT=8767
# Used to build absolute URLs for Pushover summary links.
# e.g. https://transcribe.example.com
TRANSCRIBE_UI_BASE_URL=
# Silence gap (seconds) that starts a new conversation block in the day view.
TRANSCRIBE_CONVERSATION_GAP_S=180
# Below this similarity, the UI surfaces the LLM's best speaker guess
# as a hint without committing it to the DB.
TRANSCRIBE_SUGGEST_THRESHOLD=0.55

# ---------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------
# Audio retention in days (transcripts are kept forever regardless).
TRANSCRIBE_AUDIO_RETENTION_DAYS=90
# Auto-prune oldest audio if /data free space drops below this many GB.
TRANSCRIBE_DISK_FREE_MIN_GB=5

# ---------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------
TZ=UTC
TRANSCRIBE_LOG_LEVEL=INFO
# Optional Uptime Kuma push-monitor URL; leave blank to disable.
TRANSCRIBE_UPTIME_KUMA_PUSH_URL=
